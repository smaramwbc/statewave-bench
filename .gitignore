# Benchmark artifacts — large, machine-specific, never committed.
# A sample run's results CAN be committed at release time by adding
# `!results/published/` here (or whatever subdir you choose).
data/locomo/
results/*.json
results/*.csv
results/charts/
!results/.gitkeep
!data/.gitkeep

# Secrets — operators export their own API keys per session; never check in.
.env
.env.*
!.env.example
