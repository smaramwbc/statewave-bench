# Copy to `.env` (gitignored) and fill in the keys for whichever
# systems you're benchmarking. `swb config-check` verifies these are
# wired before the bench burns tokens.

# ── Answer + judge models ─────────────────────────────────────────────
# Set whichever provider you want as the answer model — the other one
# is only needed if you're using its model as the judge OR running a
# system that uses it internally (Mem0's fact extractor defaults to
# OpenAI; you'll need OPENAI_API_KEY for Mem0 even if you use Claude
# for the answer model).

ANTHROPIC_API_KEY=sk-ant-…
OPENAI_API_KEY=sk-…

# Override the default answer / judge models if you want to run on
# something cheaper for the pilot. Defaults: Claude Sonnet 4.6 for the
# answer model, GPT-4o for the judge. Smaller alternatives:
# SWB_ANSWER_MODEL=claude-haiku-4-5-20251001
# SWB_JUDGE_MODEL=gpt-4o-mini

# ── Statewave system ──────────────────────────────────────────────────
# Point at your running Statewave server. See the deployment guide in
# statewave-connectors for setup options (Docker / Compose / Helm /
# Fly / Railway).
STATEWAVE_URL=http://localhost:8000
STATEWAVE_API_KEY=
# Optional. Set when your Statewave deployment is multi-tenant and you
# want to scope this bench's writes to a specific tenant.
# STATEWAVE_TENANT_ID=

# Experimental opt-in: bypass `get_context` and retrieve via
# `search_memories(kind="profile_fact", semantic=True)` instead. Use
# this to A/B test bundle SHAPE (compact fact list, Mem0-style) vs
# Statewave's default ranked-blend bundle. Leave unset for normal runs.
# STATEWAVE_BENCH_FACTS_ONLY=1

# ── Mem0 system ───────────────────────────────────────────────────────
# Cloud (preferred for the bench — no self-hosted infra to set up):
MEM0_API_KEY=
# Optional override — point at a Mem0-compatible host other than the
# default cloud endpoint (e.g. an enterprise proxy or a self-hosted
# Mem0 server).
# MEM0_HOST=

# ── Zep system ────────────────────────────────────────────────────────
ZEP_API_KEY=
